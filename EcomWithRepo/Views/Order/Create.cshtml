@model Ecom.ViewModels.CreateOrderVM

<form asp-action="Create" method="post">

    <div class="form-group">
        <label>Customer</label>
        <select asp-for="CustomerID" class="form-control"
                asp-items="@(new SelectList(Model.Customers, "CustomerID", "Name"))">
            <option value="">-- Select Customer --</option>

        </select>
    </div>

    <div class="form-group">
        <label>Order Date</label>
        <input asp-for="OrderDate" type="datetime-local" class="form-control" />
    </div>

    <h4>Products</h4>
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Quantity</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Products.Count; i++)
            {
                <tr>
                    <td>@Model.Products[i].ProductName</td>
                    <td>@Model.Products[i].Price</td>
                    <td>
                        <input asp-for="Products[@i].Quantity" type="number" min="0" class="form-control" />
                        <input asp-for="Products[@i].ProductID" type="hidden" />
                        <input asp-for="Products[@i].Price" type="hidden" />
                        <input asp-for="Products[@i].ProductName" type="hidden" />
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <button type="submit" class="btn btn-primary">Create Order</button>
</form>